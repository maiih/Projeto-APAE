@model Infrastructure.Models.Event

@{
    ViewData["Title"] = "Cadastro de Evento";
}

<div class="container mt-5">
    <div class="bg-success text-white p-3 rounded-top">
        <h3 class="mb-0">Cadastro de Evento</h3>
    </div>

    <div class="bg-light p-4 rounded-bottom shadow-sm border">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="text-primary fw-bold mb-1">Nome do evento</label>
                        <input asp-for="Title" class="form-control bg-secondary bg-opacity-25 border-0" required />
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Date" class="text-primary fw-bold mb-1">Data</label>
                        <input asp-for="Date" type="date" class="form-control bg-secondary bg-opacity-25 border-0 w-50" required />
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="text-primary fw-bold mb-1">Finalidade / Descrição</label>
                        <textarea asp-for="Description" class="form-control bg-secondary bg-opacity-25 border-0" rows="3"></textarea>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-3 h-100">
                        <label asp-for="ResourcesNeeded" class="text-primary fw-bold mb-1">Recursos necessários</label>
                        <span class="d-block text-muted small mb-2">Segure CTRL (ou CMD) para selecionar mais de uma opção.</span>

                        <!-- Caixa de Seleção Múltipla -->
                        <select asp-for="ResourcesNeeded" class="form-select bg-secondary bg-opacity-25 border-0" multiple style="height: 70%;">
                            <option value="Cesta básica">Cesta básica</option>
                            <option value="Ajuda financeira">Ajuda financeira</option>
                            <option value="Mão de obra">Mão de obra</option>
                            <option value="Materiais de limpeza">Materiais de limpeza</option>
                            <option value="Materiais didáticos">Materiais didáticos</option>
                            <option value="Outros">Outros</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-success px-4">Cadastrar</button>
            </div>
        </form>
    </div>
</div>