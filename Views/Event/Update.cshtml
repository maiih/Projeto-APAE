@model Infrastructure.Models.Event

@{
    ViewData["Title"] = "Editar Evento";
}

<div class="container mt-5 fade-in-up">
    <div class="bg-apae-green text-white p-3 rounded-top">
        <h3 class="mb-0">Editar Evento</h3>
    </div>

    <div class="bg-light p-4 rounded-bottom shadow-sm border card-soft" style="border: 1px solid var(--apae-green) !important;">
        <form asp-action="Update" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 border-end-md pe-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Title" class="text-apae-green fw-bold mb-1">Nome do evento</label>
                        <input asp-for="Title" class="form-control-soft w-100" required />
                    </div>

                    <div class="row">
                        <div class="form-group mb-3 col-md-6">
                            <label asp-for="Date" class="text-apae-green fw-bold mb-1">Data</label>
                            <input asp-for="Date" type="date" class="form-control-soft w-100" required />
                        </div>

                        <div class="form-group mb-3 col-md-6">
                            <label asp-for="Status" class="text-apae-green fw-bold mb-1">Status</label>
                            <select asp-for="Status" class="form-control-soft w-100" asp-items="@Html.GetEnumSelectList<Core.Enums.EventStatus>()"></select>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="text-apae-green fw-bold mb-1">Finalidade / Descrição</label>
                        <textarea asp-for="Description" class="form-control-soft w-100" rows="3"></textarea>
                    </div>
                </div>

                <div class="col-md-6 ps-md-4">
                    <div class="form-group mb-3 h-100">
                        <label asp-for="ResourcesNeeded" class="text-apae-green fw-bold mb-1">Recursos necessários</label>
                        <span class="d-block text-muted small mb-2">Segure CTRL (ou CMD) para selecionar mais de uma opção.</span>

                        <select asp-for="ResourcesNeeded" class="form-control-soft w-100" multiple style="height: 180px;">
                            <option value="Cesta básica">Cesta básica</option>
                            <option value="Ajuda financeira">Ajuda financeira</option>
                            <option value="Mão de obra">Mão de obra</option>
                            <option value="Materiais de limpeza">Materiais de limpeza</option>
                            <option value="Materiais didáticos">Materiais didáticos</option>
                            <option value="Outros">Outros</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                <a asp-action="AdminIndex" class="btn btn-apae-outline me-2 px-4 rounded-pill">Cancelar</a>
                <button type="submit" class="btn btn-apae-primary px-4 rounded-pill">Salvar Alterações</button>
            </div>
        </form>
    </div>
</div>