@{
    ViewData["Title"] = "Início";
}

<div class="container mt-2">
    <div class="fade-in-up bg-apae-green p-5 rounded-4 shadow-sm text-center mb-5 position-relative overflow-hidden">
        <div class="position-relative z-1">
            <h1 class="fw-bold display-4 mb-3">Conectando Solidariedade</h1>
            <p class="lead mx-auto text-white-50" style="max-width: 800px;">
                A Associação de Pais e Amigos dos Excepcionais é uma instituição civil beneficente. Desde 1973, somos referência regional na defesa de direitos, inclusão social e prestação de serviços para pessoas com deficiências.
            </p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4 fade-in-up" style="animation-delay: 0.1s;">
            <div class="card-soft p-4 h-100">
                <div class="d-inline-block bg-apae-yellow p-3 rounded-circle mb-3"></div>
                <h4 class="text-apae-green mb-3">Público-alvo</h4>
                <p class="text-muted">Pessoas com deficiência intelectual (níveis moderado e severo), deficiências múltiplas (física, auditiva, visual) e autismo.</p>
            </div>
        </div>

        <div class="col-md-4 fade-in-up" style="animation-delay: 0.2s;">
            <div class="card-soft p-4 h-100">
                <div class="d-inline-block bg-apae-yellow p-3 rounded-circle mb-3"></div>
                <h4 class="text-apae-green mb-3">Educação</h4>
                <p class="text-muted">Atendimento estruturado a centenas de alunos, oferecendo escolarização adaptada e acompanhamento para o desenvolvimento da independência.</p>
            </div>
        </div>

        <div class="col-md-4 fade-in-up" style="animation-delay: 0.3s;">
            <div class="card-soft p-4 h-100">
                <div class="d-inline-block bg-apae-yellow p-3 rounded-circle mb-3"></div>
                <h4 class="text-apae-green mb-3">Saúde e Reabilitação</h4>
                <p class="text-muted">Equipes multidisciplinares especializadas para promover o desenvolvimento integral, a qualidade de vida e a autonomia dos atendidos.</p>
            </div>
        </div>
    </div>

    <div class="fade-in-up text-center p-5 card-soft" style="animation-delay: 0.4s;">
        <h3 class="fw-bold mb-3">Faça Parte da Nossa História</h3>
        <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">
            Apoie nossos projetos sociais. Transforme tempo e recursos em qualidade de vida para quem precisa.
        </p>
        <a asp-controller="Event" asp-action="Index" class="btn btn-apae-primary btn-lg px-5 py-3 rounded-pill">
            Quero ser um Voluntário
        </a>
    </div>
</div>